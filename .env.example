# ============================================================
# OpenAI Realtime API 兼容服务器 - 配置文件
# 复制此文件为 .env 并填入你的配置
# 首次启动时若不存在 .env 将自动从本文件创建
# ============================================================

# ==================== 服务器配置 ====================
DEBUG=true
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS 跨域配置 (多个来源用逗号分隔)
# 开发环境(DEBUG=true): 留空则使用 allow_origins=['*']
# 生产环境(DEBUG=false): 留空则使用默认 ["http://localhost:3000", "http://localhost:8000"]
# 示例: CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=

# ============================================================
# LLM 语言模型配置 (统一 OpenAI 兼容格式)
# ============================================================
# 所有 LLM 均通过 OpenAI 兼容接口调用，只需填写以下四项：
#   LLM_MODEL_NAME  — 服务商/配置名称（仅用于标识和日志显示）
#   LLM_BASE_URL    — API 服务地址
#   LLM_MODEL_ID    — 模型 ID
#   LLM_API_KEY     — API 密钥
#
# ── 预设: 硅基流动 (SiliconFlow) ──────────────────────────
# 国内高性价比推理平台，支持 DeepSeek / Qwen 等模型
# 注册地址: https://cloud.siliconflow.cn
LLM_MODEL_NAME=SiliconFlow
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_ID=deepseek-ai/DeepSeek-V3
LLM_API_KEY=your_siliconflow_api_key_here
# 其他可选模型:
#   deepseek-ai/DeepSeek-R1
#   Qwen/Qwen3-235B-A22B
#   Qwen/Qwen2.5-72B-Instruct
#
# ── 预设: OpenAI ─────────────────────────────────────────
# 官方 OpenAI API
# LLM_MODEL_NAME=OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_ID=gpt-4o
# LLM_API_KEY=your_openai_api_key_here
#
# ── 预设: DeepSeek 官方 ──────────────────────────────────
# DeepSeek 官方 API (OpenAI 兼容)
# LLM_MODEL_NAME=DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL_ID=deepseek-chat
# LLM_API_KEY=your_deepseek_api_key_here
#
# ── 预设: Ollama (本地部署) ──────────────────────────────
# Ollama 通过 OpenAI 兼容端点提供服务，无需 API Key
# LLM_MODEL_NAME=Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_ID=llama3:8b
# LLM_API_KEY=ollama
#
# ── 预设: 通义千问 (DashScope) ───────────────────────────
# 阿里云 DashScope 通义千问 API (OpenAI 兼容)
# LLM_MODEL_NAME=DashScope
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_ID=qwen-plus
# LLM_API_KEY=your_dashscope_api_key_here

# LLM 通用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_SYSTEM_PROMPT=你是一个有帮助的AI助手。请用简洁的语言回答问题。

# ============================================================
# STT 语音转文字配置
# ============================================================
# 可选: deepgram, openai_whisper, local_whisper
STT_PROVIDER=deepgram

# ── Deepgram 配置 (STT_PROVIDER=deepgram) ────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=zh-CN

# ── OpenAI Whisper 配置 (STT_PROVIDER=openai_whisper) ────
# 留空则自动复用 LLM_API_KEY / LLM_BASE_URL
# STT_API_KEY=
# STT_BASE_URL=

# ── 本地 Whisper 配置 (STT_PROVIDER=local_whisper) ───────
WHISPER_MODEL=base
# 可选: tiny, base, small, medium, large

# ============================================================
# TTS 文字转语音配置
# ============================================================
# 可选: edge_tts, openai_tts, elevenlabs
TTS_PROVIDER=edge_tts

# ── Edge TTS 配置 (免费，微软在线服务) ───────────────────
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# 可选中文声音: zh-CN-XiaoxiaoNeural, zh-CN-YunxiNeural, zh-CN-YunjianNeural
# 代理设置 (国内网络可能需要)
EDGE_TTS_PROXY=
EDGE_TTS_CONNECT_TIMEOUT=10
EDGE_TTS_RECEIVE_TIMEOUT=60

# ── OpenAI TTS 配置 (TTS_PROVIDER=openai_tts) ───────────
# 留空则自动复用 LLM_API_KEY
# TTS_API_KEY=
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL_ID=tts-1
TTS_VOICE=alloy
# 可选: alloy, echo, fable, onyx, nova, shimmer

# ── ElevenLabs 配置 (TTS_PROVIDER=elevenlabs) ───────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_monolingual_v1

# ============================================================
# VAD 语音活动检测配置
# ============================================================
VAD_THRESHOLD=0.5
VAD_SILENCE_DURATION_MS=500
VAD_PREFIX_PADDING_MS=300
